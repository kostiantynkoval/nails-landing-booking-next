# Copy to .env: cp .env.example .env
# Uses local PostgreSQL (see DATABASE_URL). Prisma loads this via prisma.config.ts / dotenv.
DATABASE_URL="postgresql://salon_admin:YOUR_PASSWORD@localhost:5432/salon_db?schema=public"
POSTGRES_USER="admin"
POSTGRES_PASSWORD="postgr@sPassw0rd"
POSTGRES_DB="db"

# Generate: openssl rand -base64 32
AUTH_SECRET="change-me-use-openssl-rand-base64-32"
SALON_TIMEZONE="Europe/Kyiv"
GALLERY_SOURCE="static"
ADMIN_PASSWORD="Adm!nPassw0rd"
TECHNICIAN_PASSWORD="T@chPassw0rd"

# Dev seed credentials (see prisma/seed.ts)
ADMIN_PASSWORD="Adm!nPassw0rd"
